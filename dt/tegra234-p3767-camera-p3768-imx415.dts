// SPDX-License-Identifier: GPL-2.0-only
/*
 * Overlay for the Waveshare IMX415-98 camera (Sony IMX415) on the CAM1
 * 22-pin connector of the P3768 carrier board (Jetson Orin Nano devkit).
 *
 * Adapted from tegra234-p3767-camera-p3768-imx219-C.dts (same connector,
 * same reset line PAC.00, same serial_c CSI routing). The module has its
 * own 37.125 MHz crystal, so no mclk is routed from Tegra.
 *
 * Single mode: 3864x2192 RAW10 GBRG @ 30 fps, 4 lanes at 891 Mbps/lane
 * (445.5 MHz link frequency). CAM1 on P3768 has all 4 lanes wired.
 */

/dts-v1/;
/plugin/;

#define CAM0_RST	TEGRA234_MAIN_GPIO(H, 3)
#define CAM0_PWDN	TEGRA234_MAIN_GPIO(H, 6)
#define CAM1_PWDN	TEGRA234_MAIN_GPIO(AC, 0)
#define CAM_I2C_MUX 	TEGRA234_AON_GPIO(CC, 3)

#include <dt-bindings/tegra234-p3767-0000-common.h>
#include <dt-bindings/pinctrl/pinctrl-tegra.h>

/ {
	overlay-name = "Camera IMX415-98";
	jetson-header-name = "Jetson 22pin CSI Connector";
	compatible = JETSON_COMPATIBLE_P3768;

	/* IMX415 sensor module on CSI serial_c / cam1 connector */
	fragment@0 {
		target-path = "/";
		__overlay__ {
			tegra-capture-vi  {
				num-channels = <1>;
				ports {
					#address-cells = <1>;
					#size-cells = <0>;
					vi_port1: port@1 {
						reg = <0>;
						rbpcv415_imx415_vi_in1: endpoint {
							port-index = <2>;
							bus-width = <4>;
							remote-endpoint = <&rbpcv415_imx415_csi_out1>;
						};
					};
				};
			};
			tegra-camera-platform {
				compatible = "nvidia, tegra-camera-platform";
				modules {
					cam_module1: module1 {
						badge = "jakku_rear_IMX415";
						position = "rear";
						orientation = "1";
						cam_module1_drivernode0: drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/cam_i2cmux/i2c@1/rbpcv415_c@37";
						};
						cam_module1_drivernode1: drivernode1 {
							pcl_id = "v4l2_lens";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/lens_imx415@IMX41598";
						};
					};
				};
			};
			bus@0 {
				host1x@13e00000 {
					nvcsi@15a00000 {
						num-channels = <1>;
						#address-cells = <1>;
						#size-cells = <0>;
						csi_chan1: channel@1 {
							reg = <0>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								csi_chan1_port0: port@0 {
									reg = <0>;
									rbpcv415_imx415_csi_in1: endpoint@2 {
										port-index = <2>;
										bus-width = <4>;
										remote-endpoint = <&rbpcv415_imx415_out1>;
									};
								};
								csi_chan1_port1: port@1 {
									reg = <1>;
									rbpcv415_imx415_csi_out1: endpoint@3 {
										remote-endpoint = <&rbpcv415_imx415_vi_in1>;
									};
								};
							};
						};
					};
				};
				cam_i2cmux {
					status = "okay";
					compatible = "i2c-mux-gpio";
					#address-cells = <1>;
					#size-cells = <0>;
					mux-gpios = <&gpio_aon CAM_I2C_MUX GPIO_ACTIVE_HIGH>;
					i2c-parent = <&cam_i2c>;
					i2c@1 {
						status = "okay";
						reg = <1>;
						#address-cells = <1>;
						#size-cells = <0>;
						rbpcv415_c@37 {
							/* XCLR: sensor is I2C-dead while this pin is low */
							reset-gpios = <&gpio CAM1_PWDN GPIO_ACTIVE_HIGH>;
							compatible = "sony,imx415";
							/* I2C address is strapped to 0x37 on the Waveshare board */
							reg = <0x37>;
							/* V4L2 device node location */
							devnode = "video0";
							/* Physical dimensions of sensor (1.45 um pixels) */
							physical_w = "5.602";
							physical_h = "3.178";
							sensor_model = "imx415";
							use_sensor_mode_id = "true";
							/*
							 * Argus-only, kernel ignores it: our gain
							 * control is dB x gain_factor, so the camera
							 * core must convert its linear multipliers
							 * to dB before setting the control (same
							 * property as the Argus-supported FRAMOS
							 * IMX715 overlays). V4L2 semantics unchanged.
							 */
							use_decibel_gain = "true";

							mode0 { /* IMX415_MODE_3864x2192_30FPS */
								/* module's own crystal; informational, no Tegra mclk */
								mclk_khz = "37125";
								num_lanes = "4";
								tegra_sinterface = "serial_c";
								phy_mode = "DPHY";
								/* IMX415 outputs a continuous CSI clock */
								discontinuous_clk = "no";
								dpcm_enable = "false";
								cil_settletime = "0";
								active_w = "3864";
								active_h = "2192";
								mode_type = "bayer";
								pixel_phase = "gbrg";
								csi_pixel_bit_depth = "10";
								readout_orientation = "0";
								/*
								 * 445.5 MHz link freq x 2 (DDR) x 4 lanes / 10 bit
								 * = 356.4 MHz; with line_length 5280 the line rate is
								 * 67500 lines/s = the sensor's real 14.81 us line time
								 * (HMAX 1100 x 12 / 891 MHz).
								 */
								line_length = "5280";
								inherent_gain = "1";
								mclk_multiplier = "9.6";
								pix_clk_hz = "356400000";

								gain_factor = "1000";
								framerate_factor = "1000000";
								exposure_factor = "1000000";
								/* 0..30 dB in 0.3 dB steps (GAIN_PCG_0 0..100) */
								min_gain_val = "0";
								max_gain_val = "30000";
								step_gain_val = "300";
								default_gain = "0";
								min_hdr_ratio = "1";
								max_hdr_ratio = "1";
								/* full frame at 30 fps on 4 lanes at 891 Mbps */
								min_framerate = "2000000";
								max_framerate = "30000000";
								step_framerate = "1";
								default_framerate = "30000000";
								/* 4 lines .. VMAX-8 lines at 14.81 us/line */
								min_exp_time = "59";
								max_exp_time = "33200";
								step_exp_time = "1";
								default_exp_time = "16000";
								/*
								 * The sensor family transmits 1 embedded-data
								 * line per frame; without this VI discards
								 * every frame (CHANSEL_EMBED_INFRINGE seen as
								 * corr_err/err_data 16384). Same value as the
								 * working FRAMOS IMX715 overlay for this port.
								 */
								embedded_metadata_height = "1";
							};
							mode1 { /* IMX415_MODE_3864x2192_12BIT_30FPS */
								mclk_khz = "37125";
								num_lanes = "4";
								tegra_sinterface = "serial_c";
								phy_mode = "DPHY";
								discontinuous_clk = "no";
								dpcm_enable = "false";
								cil_settletime = "0";
								active_w = "3864";
								active_h = "2192";
								mode_type = "bayer";
								pixel_phase = "gbrg";
								csi_pixel_bit_depth = "12";
								readout_orientation = "0";
								/*
								 * 445.5 MHz x 2 (DDR) x 4 lanes / 12 bit
								 * = 297 MHz; line_length 4400 -> 67500
								 * lines/s = same 14.81 us line time as the
								 * 10-bit mode (HMAX 1100 unchanged).
								 */
								line_length = "4400";
								inherent_gain = "1";
								mclk_multiplier = "8.0";
								pix_clk_hz = "297000000";

								gain_factor = "1000";
								framerate_factor = "1000000";
								exposure_factor = "1000000";
								min_gain_val = "0";
								max_gain_val = "30000";
								step_gain_val = "300";
								default_gain = "0";
								min_hdr_ratio = "1";
								max_hdr_ratio = "1";
								min_framerate = "2000000";
								max_framerate = "30000000";
								step_framerate = "1";
								default_framerate = "30000000";
								min_exp_time = "59";
								max_exp_time = "33200";
								step_exp_time = "1";
								default_exp_time = "16000";
								embedded_metadata_height = "1";
							};
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									rbpcv415_imx415_out1: endpoint {
										status = "okay";
										port-index = <2>;
										bus-width = <4>;
										remote-endpoint = <&rbpcv415_imx415_csi_in1>;
									};
								};
							};
						};
					};
				};
				/*
				 * Fixed-focus M12 lens of the Waveshare IMX415-98 module
				 * (spec PDF in reference/): EFL 3.95 mm, F/2.0, 98 deg FOV,
				 * focus 20 cm..inf. Referenced by drivernode1 (v4l2_lens);
				 * Argus reports these in its camera properties. Zeros mirror
				 * the stock lens_imx219@RBPCV2 convention for unknown fields.
				 */
				lens_imx415@IMX41598 {
					min_focus_distance = "0.0";
					hyper_focal = "0.0";
					focal_length = "3.95";
					f_number = "2.0";
					aperture = "0.0";
				};
				gpio@2200000 {
					camera-control-output-low {
						gpio-hog;
						output-low;
						gpios = <CAM0_RST 0>;
						label = "cam0-rst";
					};
				};
				gpio@6000d000 {
					camera-control-output-low {
						gpio-hog;
						output-low;
						gpios = < CAM1_PWDN 0  CAM0_PWDN 0>;
						label = "cam1-pwdn", "cam0-pwdn";
					};
				};
			};
		};
	};

	/*
	 * IR-CUT fix (validated on target 2026-07-11): CAM1 connector pin 18
	 * (module FFC pin 5 "IR-CUT", the H-bridge direction input) is the
	 * extperiph2_clk_pp1 pad. Stock pinmux = EXTPERIPH2 with the clock
	 * gated, so the pad force-drove the line to 0 V = night mode and the
	 * module's own day/night switch was overridden. Muxing to RSVD1 (=
	 * GPIO mode) leaves the pad hi-Z while GPIO PP.01 (main gpio line 113)
	 * is unclaimed - the physical switch works - and software selects the
	 * mode by driving PP.01 (gpioset/libgpiod). No gpio-hog on purpose.
	 */
	fragment@1 {
		target = <&pinmux>;
		__overlay__ {
			pinctrl-names = "default";
			pinctrl-0 = <&imx415_ircut_state>;
			imx415_ircut_state: imx415-ircut {
				ircut-pin {
					nvidia,pins = "extperiph2_clk_pp1";
					nvidia,function = "rsvd1";
					nvidia,pull = <TEGRA_PIN_PULL_NONE>;
					nvidia,tristate = <TEGRA_PIN_DISABLE>;
					nvidia,enable-input = <TEGRA_PIN_DISABLE>;
				};
			};
		};
	};
};
